FROM ubuntu:22.04
USER root
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    curl sudo iproute2 iputils-ping net-tools \
    openssh-server

RUN mkdir -p /root/admin/base
WORKDIR /root/admin/base
COPY ./dockerfiles/base/admin/ /root/admin/base/
COPY ./common/id_ed25519.pub /root/admin/base/common/id_ed25519.pub
RUN chmod +x /root/admin/base/start.sh

ENTRYPOINT ["/root/admin/base/start.sh"]

